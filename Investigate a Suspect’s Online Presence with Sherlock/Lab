#!/usr/bin/env python3
import os
import re
import json
from datetime import datetime

def analyze_sherlock_results(results_dir):
    """Analyze Sherlock result files"""
    findings = {}
    
    for filename in os.listdir(results_dir):
        if filename.startswith('sherlock_') and filename.endswith('.txt'):
            username = filename.replace('sherlock_', '').replace('.txt', '').split('_')[0]
            
            filepath = os.path.join(results_dir, filename)
            
            try:
                with open(filepath, 'r') as f:
                    content = f.read()
                
                # Count found profiles
                found_profiles = content.count('[+]')
                total_searches = content.count('Checking username')
                
                findings[username] = {
                    'found_profiles': found_profiles,
                    'total_searches': total_searches,
                    'success_rate': round((found_profiles / total_searches * 100), 2) if total_searches > 0 else 0
                }
                
            except Exception as e:
                print(f"[-] Error analyzing {filename}: {str(e)}")
    
    return findings

def generate_analysis_report(findings, output_file):
    """Generate a comprehensive analysis report"""
    with open(output_file, 'w') as f:
        f.write("OSINT Investigation Analysis Report\n")
        f.write("=" * 40 + "\n")
        f.write(f"Analysis Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n")
        
        if not findings:
            f.write("No findings to analyze.\n")
            return
        
        f.write("Username Analysis Summary:\n")
        f.write("-" * 30 + "\n")
        
        total_profiles = 0
        for username, data in findings.items():
            f.write(f"\nUsername: {username}\n")
            f.write(f"  Found Profiles: {data['found_profiles']}\n")
            f.write(f"  Total Searches: {data['total_searches']}\n")
            f.write(f"  Success Rate: {data['success_rate']}%\n")
            total_profiles += data['found_profiles']
        
        f.write(f"\nOverall Statistics:\n")
        f.write(f"Total Usernames Analyzed: {len(findings)}\n")
        f.write(f"Total Profiles Found: {total_profiles}\n")
        f.write(f"Average Profiles per Username: {round(total_profiles / len(findings), 2)}\n")
        
        # Identify most successful usernames
        sorted_findings = sorted(findings.items(), key=lambda x: x[1]['found_profiles'], reverse=True)
        
        f.write(f"\nTop Usernames by Profile Count:\n")
        f.write("-" * 35 + "\n")
        for i, (username, data) in enumerate(sorted_findings[:5], 1):
            f.write(f"{i}. {username}: {data['found_profiles']} profiles\n")

def main():
    results_dir = "../investigation_results"
    batch_results_dir = "../batch_investigation_results"
    
    print("[+] Starting analysis of investigation results...")
    
    # Analyze results from both directories
    all_findings = {}
    
    if os.path.exists(results_dir):
        findings1 = analyze_sherlock_results(results_dir)
        all_findings.update(findings1)
        print(f"[+] Analyzed {len(findings1)} results from {results_dir}")
    
    if os.path.exists(batch_results_dir):
        findings2 = analyze_sherlock_results(batch_results_dir)
        all_findings.update(findings2)
        print(f"[+] Analyzed {len(findings2)} results from {batch_results_dir}")
    
    if not all_findings:
        print("[-] No results found to analyze")
        return
    
    # Generate analysis report
    analysis_file = f"../analysis_report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
    generate_analysis_report(all_findings, analysis_file)
    
    print(f"[+] Analysis completed! Report saved to: {analysis_file}")
    
    # Display summary
    print("\n" + "=" * 40)
    print("QUICK SUMMARY")
    print("=" * 40)
    
    total_profiles = sum(data['found_profiles'] for data in all_findings.values())
    print(f"Total Usernames Analyzed: {len(all_findings)}")
    print(f"Total Profiles Found: {total_profiles}")
    
    if all_findings:
        avg_profiles = round(total_profiles / len(all_findings), 2)
        print(f"Average Profiles per Username: {avg_profiles}")

if __name__ == "__main__":
    main()
