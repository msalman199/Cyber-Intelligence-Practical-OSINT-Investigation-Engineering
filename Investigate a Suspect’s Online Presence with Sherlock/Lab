#!/usr/bin/env python3
import subprocess
import sys
import os
from datetime import datetime

def search_username_sherlock(username, output_dir):
    """Search username using Sherlock"""
    print(f"[+] Searching for {username} using Sherlock...")
    
    sherlock_path = "../sherlock"
    output_file = f"{output_dir}/sherlock_{username}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
    
    try:
        cmd = [
            "python3", f"{sherlock_path}/sherlock.py", 
            username, 
            "--output", output_file,
            "--timeout", "10"
        ]
        
        result = subprocess.run(cmd, capture_output=True, text=True)
        
        if result.returncode == 0:
            print(f"[+] Sherlock search completed. Results saved to: {output_file}")
            return output_file
        else:
            print(f"[-] Sherlock search failed: {result.stderr}")
            return None
            
    except Exception as e:
        print(f"[-] Error running Sherlock: {str(e)}")
        return None

def search_username_maigret(username, output_dir):
    """Search username using Maigret"""
    print(f"[+] Searching for {username} using Maigret...")
    
    try:
        cmd = [
            "maigret", 
            username, 
            "--folderoutput", f"{output_dir}/maigret_{username}_{datetime.now().strftime('%Y%m%d_%H%M%S')}/",
            "--html",
            "--timeout", "15"
        ]
        
        result = subprocess.run(cmd, capture_output=True, text=True)
        
        if result.returncode == 0:
            print(f"[+] Maigret search completed successfully")
            return True
        else:
            print(f"[-] Maigret search failed: {result.stderr}")
            return False
            
    except Exception as e:
        print(f"[-] Error running Maigret: {str(e)}")
        return False

def main():
    if len(sys.argv) != 2:
        print("Usage: python3 username_searcher.py <username>")
        sys.exit(1)
    
    username = sys.argv[1]
    output_dir = "../investigation_results"
    
    # Create output directory
    os.makedirs(output_dir, exist_ok=True)
    
    print(f"[+] Starting investigation for username: {username}")
    print(f"[+] Results will be saved to: {output_dir}")
    print("-" * 50)
    
    # Run Sherlock search
    sherlock_result = search_username_sherlock(username, output_dir)
    
    print("-" * 50)
    
    # Run Maigret search
    maigret_result = search_username_maigret(username, output_dir)
    
    print("-" * 50)
    print("[+] Investigation completed!")
    
    if sherlock_result:
        print(f"[+] Sherlock results: {sherlock_result}")
    if maigret_result:
        print(f"[+] Maigret results saved to output directory")

if __name__ == "__main__":
    main()
Make the script executable:

chmod +x username_searcher.py
