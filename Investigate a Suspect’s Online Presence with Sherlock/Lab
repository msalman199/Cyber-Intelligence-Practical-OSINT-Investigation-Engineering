#!/usr/bin/env python3
import subprocess
import sys
import os
from datetime import datetime
import time

def read_usernames_from_file(filename):
    """Read usernames from a text file"""
    try:
        with open(filename, 'r') as file:
            usernames = [line.strip() for line in file if line.strip()]
        return usernames
    except FileNotFoundError:
        print(f"[-] File {filename} not found")
        return []
    except Exception as e:
        print(f"[-] Error reading file: {str(e)}")
        return []

def create_investigation_report(usernames, output_dir):
    """Create a summary report of the investigation"""
    report_file = f"{output_dir}/investigation_summary_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
    
    with open(report_file, 'w') as f:
        f.write("OSINT Username Investigation Report\n")
        f.write("=" * 40 + "\n")
        f.write(f"Investigation Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        f.write(f"Total Usernames Investigated: {len(usernames)}\n")
        f.write("\nUsernames Investigated:\n")
        f.write("-" * 25 + "\n")
        
        for i, username in enumerate(usernames, 1):
            f.write(f"{i}. {username}\n")
        
        f.write("\nInvestigation Tools Used:\n")
        f.write("- Sherlock: Username search across social platforms\n")
        f.write("- Maigret: Advanced username analysis with metadata\n")
        f.write("\nNote: Check individual result files for detailed findings.\n")
    
    print(f"[+] Investigation summary saved to: {report_file}")

def search_single_username(username, output_dir):
    """Search a single username using both tools"""
    print(f"\n[+] Investigating username: {username}")
    print("-" * 30)
    
    # Sherlock search
    sherlock_cmd = [
        "python3", "../sherlock/sherlock.py",
        username,
        "--output", f"{output_dir}/sherlock_{username}.txt",
        "--timeout", "10"
    ]
    
    try:
        print("[+] Running Sherlock search...")
        subprocess.run(sherlock_cmd, check=True)
        print("[+] Sherlock search completed")
    except subprocess.CalledProcessError:
        print("[-] Sherlock search failed")
    
    # Small delay between searches
    time.sleep(2)
    
    # Maigret search
    maigret_cmd = [
        "maigret",
        username,
        "--folderoutput", f"{output_dir}/maigret_{username}/",
        "--html",
        "--timeout", "15"
    ]
    
    try:
        print("[+] Running Maigret search...")
        subprocess.run(maigret_cmd, check=True)
        print("[+] Maigret search completed")
    except subprocess.CalledProcessError:
        print("[-] Maigret search failed")

def main():
    if len(sys.argv) != 2:
        print("Usage: python3 batch_username_searcher.py <usernames_file>")
        print("Example: python3 batch_username_searcher.py ../usernames.txt")
        sys.exit(1)
    
    usernames_file = sys.argv[1]
    output_dir = "../batch_investigation_results"
    
    # Create output directory
    os.makedirs(output_dir, exist_ok=True)
    
    # Read usernames from file
    usernames = read_usernames_from_file(usernames_file)
    
    if not usernames:
        print("[-] No usernames found in file")
        sys.exit(1)
    
    print(f"[+] Starting batch investigation for {len(usernames)} usernames")
    print(f"[+] Results will be saved to: {output_dir}")
    
    # Process each username
    for i, username in enumerate(usernames, 1):
        print(f"\n[+] Processing {i}/{len(usernames)}: {username}")
        search_single_username(username, output_dir)
        
        # Add delay between usernames to avoid rate limiting
        if i < len(usernames):
            print("[+] Waiting 5 seconds before next search...")
            time.sleep(5)
    
    # Create summary report
    create_investigation_report(usernames, output_dir)
    
    print("\n" + "=" * 50)
    print("[+] Batch investigation completed!")
    print(f"[+] All results saved to: {output_dir}")

if __name__ == "__main__":
    main()
