Subtask 3.3: Configure OPSEC Toolkit
Step 1: Create OPSEC management script:

cat << 'EOF' > ~/opsec_manager.sh
#!/bin/bash

# OPSEC Manager Script for Secure Investigations

show_menu() {
    echo "=================================="
    echo "    OPSEC Investigation Manager    "
    echo "=================================="
    echo "1. Start Secure Session"
    echo "2. Check Tor Connection"
    echo "3. Clear Browser Data"
    echo "4. Secure File Deletion"
    echo "5. Network Anonymity Check"
    echo "6. Exit"
    echo "=================================="
}

start_secure_session() {
    echo "Starting secure investigation session..."
    
    # Start Tor if not running
    sudo systemctl start tor
    sleep 5
    
    # Clear any existing browser data
    bleachbit --clean firefox.cache firefox.cookies firefox.history 2>/dev/null
    
    # Start Tor Browser
    tor-browser &
    
    echo "Secure session started. Use Tor Browser for investigations."
}

check_tor() {
    echo "Checking Tor connection..."
    
    # Check if Tor service is running
    if systemctl is-active --quiet tor; then
        echo "✓ Tor service is running"
        
        # Check IP through Tor
        TOR_IP=$(proxychains4 curl -s https://ipinfo.io/ip 2>/dev/null)
        REAL_IP=$(curl -s https://ipinfo.io/ip 2>/dev/null)
        
        echo "Real IP: $REAL_IP"
        echo "Tor IP: $TOR_IP"
        
        if [ "$TOR_IP" != "$REAL_IP" ]; then
            echo "✓ Tor is working correctly"
        else
            echo "✗ Tor may not be working properly"
        fi
    else
        echo "✗ Tor service is not running"
    fi
}

clear_browser_data() {
    echo "Clearing browser data..."
    
    # Clear Firefox data
    bleachbit --clean firefox.cache firefox.cookies firefox.history firefox.session_restore
    
    # Clear system temporary files
    sudo bleachbit --clean system.cache system.tmp
    
    echo "Browser data cleared"
}

secure_delete() {
    read -p "Enter file/directory path to securely delete: " target
    if [ -e "$target" ]; then
        ~/secure_delete.sh "$target"
    else
        echo "File/directory not found: $target"
    fi
}

anonymity_check() {
    echo "Performing anonymity check..."
    
    # Check DNS leaks
    echo "Checking DNS..."
    proxychains4 nslookup google.com 2>/dev/null | grep -A1 "Server:"
    
    # Check WebRTC leaks (basic check)
    echo "Checking for potential leaks..."
    ss -tuln | grep -E ":(9050|9051)" && echo "✓ Tor ports active" || echo "✗ Tor ports not found"
    
    # Check system time (should be UTC for better anonymity)
    echo "System timezone: $(timedatectl show --property=Timezone --value)"
}

while true; do
    show_menu
    read -p "Select an option (1-6): " choice
    
    case $choice in
        1) start_secure_session ;;
        2) check_tor ;;
        3) clear_browser_data ;;
        4) secure_delete ;;
        5) anonymity_check ;;
        6) echo "Exiting..."; exit 0 ;;
        *) echo "Invalid option. Please try again." ;;
    esac
    
    echo
    read -p "Press Enter to continue..."
    clear
done
EOF

chmod +x ~/opsec_manager.sh
