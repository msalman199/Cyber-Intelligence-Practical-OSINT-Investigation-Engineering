#!/bin/bash
# Batch analyze multiple images

IMAGE_DIR="../images"
RESULTS_DIR="../results"
LAT="40.7128"
LON="-74.0060"
TZ="America/New_York"

mkdir -p "$RESULTS_DIR"

for img in "$IMAGE_DIR"/*.jpg; do
    filename=$(basename "$img")
    echo "Analyzing $filename..."
    python3 analyze_photo.py "$img" "$LAT" "$LON" "$TZ" > "$RESULTS_DIR/${filename%.jpg}_results.json"
done

echo "Batch analysis complete. Results in $RESULTS_DIR"
chmod +x batch_analyze.sh
./batch_analyze.sh
