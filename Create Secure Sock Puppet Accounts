Task 3: Configure Secure Browser Environment
Step 1: Create Browser Configuration Script
nano browser_setup.sh
#!/bin/bash

echo "=== BROWSER OPSEC CONFIGURATION ==="

# Create dedicated Firefox profile
firefox -CreateProfile "sockpuppet"

PROFILE_DIR="$HOME/.mozilla/firefox/sockpuppet"
mkdir -p "$PROFILE_DIR"

# Create privacy-focused user.js
cat > "$PROFILE_DIR/user.js" << 'EOF'
// Disable telemetry and data collection
user_pref("toolkit.telemetry.enabled", false);
user_pref("datareporting.healthreport.uploadEnabled", false);

// Disable location services
user_pref("geo.enabled", false);

// Disable WebRTC (prevents IP leaks)
user_pref("media.peerconnection.enabled", false);

// Enable fingerprinting protection
user_pref("privacy.resistFingerprinting", true);

// Disable prefetching
user_pref("network.prefetch-next", false);
user_pref("network.dns.disablePrefetch", true);

// Clear data on shutdown
user_pref("privacy.sanitize.sanitizeOnShutdown", true);
user_pref("privacy.clearOnShutdown.cache", true);
user_pref("privacy.clearOnShutdown.cookies", true);
user_pref("privacy.clearOnShutdown.history", true);

// Disable password saving
user_pref("signon.rememberSignons", false);
EOF

echo "Browser profile configured!"
echo "Launch with: firefox -P sockpuppet -no-remote"
Step 2: Execute Browser Setup
chmod +x browser_setup.sh
./browser_setup.sh
