Create a Python script to control Tor programmatically:

# Create tor_controller.py
cat > ~/tor_controller.py << 'EOF'
#!/usr/bin/env python3
"""
Tor Controller Script for Automated Proxy Management
"""

import time
import requests
from stem import Signal
from stem.control import Controller
import socket
import json

class TorController:
    def __init__(self, control_port=9051, socks_port=9050):
        self.control_port = control_port
        self.socks_port = socks_port
        self.session = requests.Session()
        
        # Configure requests to use Tor SOCKS proxy
        self.session.proxies = {
            'http': f'socks5://127.0.0.1:{socks_port}',
            'https': f'socks5://127.0.0.1:{socks_port}'
        }
    
    def get_current_ip(self):
        """Get current IP address through Tor"""
        try:
            response = self.session.get('https://httpbin.org/ip', timeout=10)
            return response.json()['origin']
        except Exception as e:
            return f"Error getting IP: {e}"
    
    def new_identity(self):
        """Request new Tor identity"""
        try:
            with Controller.from_port(port=self.control_port) as controller:
                controller.authenticate()
                controller.signal(Signal.NEWNYM)
                print("New Tor identity requested")
                time.sleep(5)  # Wait for new circuit
                return True
        except Exception as e:
            print(f"Error requesting new identity: {e}")
            return False
    
    def get_circuit_info(self):
        """Get current Tor circuit information"""
        try:
            with Controller.from_port(port=self.control_port) as controller:
                controller.authenticate()
                circuits = list(controller.get_circuits())
                if circuits:
                    circuit = circuits[0]
                    path = " -> ".join([f"{hop.fingerprint[:8]}({hop.nickname})" 
                                      for hop in circuit.path])
                    return f"Circuit: {path}"
                return "No active circuits"
        except Exception as e:
            return f"Error getting circuit info: {e}"
    
    def automated_research(self, queries, delay=10):
        """Perform automated research with identity rotation"""
        results = []
        
        for i, query in enumerate(queries):
            print(f"\n--- Research Query {i+1}: {query} ---")
            
            # Get current IP and circuit
            current_ip = self.get_current_ip()
            circuit_info = self.get_circuit_info()
            
            print(f"Current IP: {current_ip}")
            print(f"{circuit_info}")
            
            # Simulate research (replace with actual research logic)
            try:
                # Example: Search DuckDuckGo
                search_url = f"https://duckduckgo.com/html/?q={query.replace(' ', '+')}"
                response = self.session.get(search_url, timeout=15)
                
                result = {
                    'query': query,
                    'ip': current_ip,
                    'circuit': circuit_info,
                    'status': 'Success' if response.status_code == 200 else 'Failed',
                    'timestamp': time.strftime('%Y-%m-%d %H:%M:%S')
                }
                results.append(result)
                
                print(f"Research completed: {result['status']}")
                
            except Exception as e:
                result = {
                    'query': query,
                    'ip': current_ip,
                    'circuit': circuit_info,
                    'status': f'Error: {e}',
                    'timestamp': time.strftime('%Y-%m-%d %H:%M:%S')
                }
                results.append(result)
            
            # Request new identity for next query (except last one)
            if i < len(queries) - 1:
                print("Requesting new identity...")
                self.new_identity()
                time.sleep(delay)
        
        return results

def main():
    print("Tor Automated Research Controller")
    print("=================================")
    
    # Initialize controller
    tor_ctrl = TorController()
    
    # Test basic functionality
    print(f"Initial IP: {tor_ctrl.get_current_ip()}")
    print(f"Initial {tor_ctrl.get_circuit_info()}")
    
    # Example research queries
    research_queries = [
        "cybersecurity best practices",
        "OSINT investigation techniques",
        "digital forensics tools",
        "network security analysis"
    ]
    
    # Perform automated research
    print("\nStarting automated research...")
    results = tor_ctrl.automated_research(research_queries, delay=15)
    
    # Save results
    with open('research_results.json', 'w') as f:
        json.dump(results, f, indent=2)
    
    print("\nResearch Results Summary:")
    print("========================")
    for result in results:
        print(f"Query: {result['query']}")
        print(f"Status: {result['status']}")
        print(f"IP: {result['ip']}")
        print(f"Time: {result['timestamp']}")
        print("-" * 40)

if __name__ == "__main__":
    main()
EOF

