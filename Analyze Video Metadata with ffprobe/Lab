Task 2: Advanced Analysis with Forensic Tools
Step 1: Install Additional Tools
# Install ExifTool
sudo apt update
sudo apt install libimage-exiftool-perl -y

# Install MediaInfo
sudo apt install mediainfo -y

# Verify installations
exiftool -ver
mediainfo --version
Step 2: Extract Metadata with ExifTool
# Display all metadata
exiftool sample_video.mp4

# Export to JSON
exiftool -json sample_video.mp4 > exiftool_output.json

# Extract specific fields
exiftool -CreateDate -ModifyDate -Duration -ImageSize sample_video.mp4

# Check for GPS data
exiftool -gps:all -c "%.6f" sample_video.mp4
Step 3: Analyze with MediaInfo
# Full media information
mediainfo sample_video.mp4

# Export to JSON
mediainfo --Output=JSON sample_video.mp4 > mediainfo_output.json

# Extract specific stream information
mediainfo --Inform="Video;%Format%,%Width%,%Height%,%FrameRate%" sample_video.mp4
