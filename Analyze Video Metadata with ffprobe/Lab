Task 1: Basic Metadata Extraction with ffprobe
Step 1: Verify Installation and Explore Sample Files
# Check ffprobe version
ffprobe -version

# Navigate to sample directory
cd /home/student/lab20-samples
ls -lh

# View basic file information
file sample_video.mp4
Step 2: Extract Basic Video Metadata
# Display general information
ffprobe -i sample_video.mp4

# Extract format information in JSON
ffprobe -v quiet -print_format json -show_format sample_video.mp4

# Extract stream information
ffprobe -v quiet -print_format json -show_streams sample_video.mp4

# Save complete metadata
ffprobe -v quiet -print_format json -show_format -show_streams sample_video.mp4 > metadata.json
Step 3: Extract Specific Metadata Fields
# Video stream properties only
ffprobe -v quiet -select_streams v:0 -show_entries stream=width,height,codec_name,duration,bit_rate -of csv=p=0 sample_video.mp4

# Extract creation timestamp
ffprobe -v quiet -show_entries format_tags=creation_time -of default=noprint_wrappers=1:nokey=1 sample_video.mp4

# Frame-level analysis (first 20 frames)
ffprobe -v quiet -select_streams v:0 -show_entries frame=n,pts_time,pkt_size -of csv sample_video.mp4 | head -20
