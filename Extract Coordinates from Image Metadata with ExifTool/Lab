cat > ~/gps_lab/scripts/extract_gps.sh << 'EOF'
#!/bin/bash
# GPS Extraction Script
# Usage: ./extract_gps.sh IMAGE.jpg

if [ $# -eq 0 ]; then
    echo "Usage: $0 <image_file>"
    exit 1
fi

IMAGE="$1"

# TODO: Add file existence check

# Extract GPS coordinates in decimal format
LAT=$(exiftool -GPSLatitude -n "$IMAGE" 2>/dev/null | cut -d':' -f2 | tr -d ' ')
LON=$(exiftool -GPSLongitude -n "$IMAGE" 2>/dev/null | cut -d':' -f2 | tr -d ' ')

# TODO: Extract altitude and timestamp
# TODO: Check if GPS data exists
# TODO: Generate Google Maps URL

echo "Latitude: $LAT"
echo "Longitude: $LON"
echo "Google Maps: https://www.google.com/maps?q=$LAT,$LON"
EOF

