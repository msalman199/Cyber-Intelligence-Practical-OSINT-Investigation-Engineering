#!/usr/bin/env python3
"""
Reverse Search Automation Tool
Prepares images and generates search URLs for manual verification
"""

import os
import hashlib
import shutil
from urllib.parse import quote
import base64

class ReverseSearchHelper:
    def __init__(self, image_directory):
        self.image_directory = image_directory
        self.output_directory = "reverse_search_prep"
        
    def setup_output_directory(self):
        """Create output directory for prepared images"""
        if not os.path.exists(self.output_directory):
            os.makedirs(self.output_directory)
    
    def calculate_image_hash(self, image_path):
        """Calculate MD5 hash of image for tracking"""
        with open(image_path, 'rb') as f:
            return hashlib.md5(f.read()).hexdigest()
    
    def prepare_images_for_search(self):
        """Prepare images and generate search URLs"""
        self.setup_output_directory()
        
        search_urls_file = os.path.join(self.output_directory, 'search_urls.txt')
        image_hashes_file = os.path.join(self.output_directory, 'image_hashes.txt')
        
        with open(search_urls_file, 'w') as url_file, \
             open(image_hashes_file, 'w') as hash_file:
            
            url_file.write("Reverse Search URLs for Manual Investigation\n")
            url_file.write("=" * 50 + "\n\n")
            
            hash_file.write("Image Hash Tracking\n")
            hash_file.write("=" * 20 + "\n\n")
            
            for filename in os.listdir(self.image_directory):
                if filename.lower().endswith(('.jpg', '.jpeg', '.png')):
                    image_path = os.path.join(self.image_directory, filename)
                    image_hash = self.calculate_image_hash(image_path)
                    
                    # Copy image to output directory
                    output_image_path = os.path.join(self.output_directory, filename)
                    shutil.copy2(image_path, output_image_path)
                    
                    # Generate search URLs
                    url_file.write(f"Image: {filename}\n")
                    url_file.write(f"Hash: {image_hash}\n")
                    url_file.write("Search URLs:\n")
                    url_file.write(f"  Yandex: https://yandex.com/images/search?rpt=imageview&url=\n")
                    url_file.write(f"  TinEye: https://tineye.com/search\n")
                    url_file.write(f"  Bing: https://www.bing.com/images/search?view=detailv2&iss=sbi\n")
                    url_file.write("\n" + "-" * 40 + "\n\n")
                    
                    # Record hash
                    hash_file.write(f"{filename}: {image_hash}\n")
        
        print(f"Images prepared in: {self.output_directory}")
        print(f"Search URLs saved in: {search_urls_file}")
        print(f"Image hashes saved in: {image_hashes_file}")

def main():
    import sys
    if len(sys.argv) != 2:
        print("Usage: python3 reverse_search_automation.py <image_directory>")
        return
    
    image_dir = sys.argv[1]
    if not os.path.exists(image_dir):
        print(f"Error: Directory {image_dir} does not exist")
        return
    
    helper = ReverseSearchHelper(image_dir)
    helper.prepare_images_for_search()

if __name__ == "__main__":
    main()
