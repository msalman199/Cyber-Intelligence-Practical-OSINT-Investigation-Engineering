#!/usr/bin/env python3
"""
Comprehensive Facial Analysis and Cross-Reference Tool
"""

import json
import csv
import os
from datetime import datetime

class ComprehensiveAnalyzer:
    def __init__(self):
        self.analysis_dir = "analysis_output"
        self.search_dir = "reverse_search_prep"
        self.final_report_dir = "final_analysis"
        
    def setup_final_directory(self):
        if not os.path.exists(self.final_report_dir):
            os.makedirs(self.final_report_dir)
    
    def load_metadata_files(self):
        """Load all metadata JSON files"""
        metadata_files = {}
        
        if os.path.exists(self.analysis_dir):
            for filename in os.listdir(self.analysis_dir):
                if filename.endswith('_metadata.json'):
                    filepath = os.path.join(self.analysis_dir, filename)
                    with open(filepath, 'r') as f:
                        image_name = filename.replace('_metadata.json', '')
                        metadata_files[image_name] = json.load(f)
        
        return metadata_files
    
    def load_hash_data(self):
        """Load image hash data"""
        hash_file = os.path.join(self.search_dir, 'image_hashes.txt')
        hashes = {}
        
        if os.path.exists(hash_file):
            with open(hash_file, 'r') as f:
                for line in f:
                    if ':' in line and not line.startswith('Image Hash'):
                        parts = line.strip().split(': ')
                        if len(parts) == 2:
                            hashes[parts[0]] = parts[1]
        
        return hashes
    
    def generate_investigation_report(self):
        """Generate final investigation report"""
        self.setup_final_directory()
        
        metadata_files = self.load_metadata_files()
        hash_data = self.load_hash_data()
        
        report_file = os.path.join(self.final_report_dir, 'investigation_report.md')
        
        with open(report_file, 'w') as f:
            f.write("# Facial Feature Analysis Investigation Report\n\n")
            f.write(f"Generated on: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n")
            
            f.write("## Executive Summary\n\n")
            f.write(f"Total images analyzed: {len(metadata_files)}\n")
            f.write(f"Images with facial metadata: {sum(1 for data in metadata_files.values() if len(data) > 3)}\n\n")
            
            f.write("## Detailed Analysis\n\n")
            
            for image_name, metadata in metadata_files.items():
                f.write(f"### {image_name}\n\n")
                f.write(f"**File Hash:** {hash_data.get(image_name + '.jpg', 'Not available')}\n\n")
                
                # Camera information
                if 'Make' in metadata or 'Model' in metadata:
                    f.write("**Camera Information:**\n")
                    f.write(f"- Make: {metadata.get('Make', 'Unknown')}\n")
                    f.write(f"- Model: {metadata.get('Model', 'Unknown')}\n")
                    f.write(f"- DateTime: {metadata.get('DateTime', 'Unknown')}\n\n")
                
                # GPS information
                if 'GPSPosition' in metadata:
                    f.write("**Location Data:**\n")
                    f.write(f"- GPS Position: {metadata.get('GPSPosition', 'Not available')}\n\n")
                
                # Facial detection data
                facial_fields = ['FaceDetect', 'RegionInfo', 'FaceCount']
                facial_data_found = any(field in metadata for field in facial_fields)
                
                if facial_data_found:
                    f.write("**Facial Detection Data:**\n")
                    for field in facial_fields:
                        if field in metadata:
                            f.write(f"- {field}: {metadata[field]}\n")
                    f.write("\n")
                else:
                    f.write("**Facial Detection Data:** None detected\n\n")
                
                f.write("**Recommended Actions:**\n")
                f.write("- Perform reverse image search using prepared URLs\n")
                f.write("- Cross-reference with social media platforms\n")
                f.write("- Verify metadata authenticity\n")
                if 'GPSPosition' in metadata:
                    f.write("- Investigate location context\n")
                f.write("\n---\n\n")
            
            f.write("## Investigation Guidelines\n\n")
            f.write("1. **Ethical Considerations:** Ensure all analysis complies with privacy laws\n")
            f.write("2. **Verification:** Cross-reference findings with multiple sources\n")
            f.write("3. **Documentation:** Maintain detailed records of all searches performed\n")
            f.write("4. **Legal Compliance:** Follow applicable laws and regulations\n\n")
            
            f.write("## Next Steps\n\n")
            f.write("1. Review prepared search URLs in reverse_search_prep directory\n")
            f.write("2. Manually perform reverse image searches\n")
            f.write("3. Document findings in investigation case file\n")
            f.write("4. Consider additional OSINT techniques as needed\n")
        
        print(f"Investigation report generated: {report_file}")

def main():
    analyzer = ComprehensiveAnalyzer()
    analyzer.generate_investigation_report()

if __name__ == "__main__":
    main()
