#!/usr/bin/env python3
"""
Facial Feature Analysis Tool
Automates metadata extraction and prepares images for reverse search
"""

import os
import json
import subprocess
import csv
from datetime import datetime
import argparse

class FacialAnalyzer:
    def __init__(self, input_directory):
        self.input_directory = input_directory
        self.output_directory = "analysis_output"
        self.supported_formats = ['.jpg', '.jpeg', '.png', '.tiff', '.bmp']
        
    def setup_output_directory(self):
        """Create output directory if it doesn't exist"""
        if not os.path.exists(self.output_directory):
            os.makedirs(self.output_directory)
            print(f"Created output directory: {self.output_directory}")
    
    def find_images(self):
        """Find all supported image files in the input directory"""
        images = []
        for filename in os.listdir(self.input_directory):
            if any(filename.lower().endswith(ext) for ext in self.supported_formats):
                images.append(os.path.join(self.input_directory, filename))
        return images
    
    def extract_metadata(self, image_path):
        """Extract metadata using ExifTool"""
        try:
            cmd = ['exiftool', '-json', image_path]
            result = subprocess.run(cmd, capture_output=True, text=True)
            
            if result.returncode == 0:
                metadata = json.loads(result.stdout)[0]
                return metadata
            else:
                print(f"Error extracting metadata from {image_path}")
                return None
        except Exception as e:
            print(f"Exception occurred: {e}")
            return None
    
    def extract_facial_features(self, metadata):
        """Extract facial feature related metadata"""
        facial_data = {}
        
        # Common facial detection fields
        facial_fields = [
            'FaceDetect', 'RegionInfo', 'FaceRegions', 'DetectedFaces',
            'FaceCount', 'FacePositions', 'PersonInImage'
        ]
        
        for field in facial_fields:
            if field in metadata:
                facial_data[field] = metadata[field]
        
        # GPS data for location context
        gps_fields = ['GPSLatitude', 'GPSLongitude', 'GPSPosition']
        for field in gps_fields:
            if field in metadata:
                facial_data[field] = metadata[field]
        
        # Camera information
        camera_fields = ['Make', 'Model', 'DateTime', 'Software']
        for field in camera_fields:
            if field in metadata:
                facial_data[field] = metadata[field]
        
        return facial_data
    
    def generate_report(self, analysis_results):
        """Generate comprehensive analysis report"""
        report_file = os.path.join(self.output_directory, 'facial_analysis_report.csv')
        
        with open(report_file, 'w', newline='') as csvfile:
            fieldnames = ['Filename', 'HasFacialData', 'FaceCount', 'GPS_Available', 
                         'Camera_Make', 'Camera_Model', 'DateTime', 'FileSize']
            writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
            
            writer.writeheader()
            for result in analysis_results:
                writer.writerow(result)
        
        print(f"Report generated: {report_file}")
    
    def analyze_bulk_images(self):
        """Main function to analyze all images"""
        self.setup_output_directory()
        images = self.find_images()
        
        if not images:
            print("No supported images found in the input directory")
            return
        
        print(f"Found {len(images)} images to analyze")
        analysis_results = []
        
        for image_path in images:
            print(f"Analyzing: {os.path.basename(image_path)}")
            
            metadata = self.extract_metadata(image_path)
            if metadata:
                facial_data = self.extract_facial_features(metadata)
                
                # Prepare result summary
                result = {
                    'Filename': os.path.basename(image_path),
                    'HasFacialData': len(facial_data) > 3,  # More than just camera info
                    'FaceCount': facial_data.get('FaceCount', 'Unknown'),
                    'GPS_Available': 'GPSPosition' in facial_data,
                    'Camera_Make': facial_data.get('Make', 'Unknown'),
                    'Camera_Model': facial_data.get('Model', 'Unknown'),
                    'DateTime': facial_data.get('DateTime', 'Unknown'),
                    'FileSize': metadata.get('FileSize', 'Unknown')
                }
                
                analysis_results.append(result)
                
                # Save individual metadata
                metadata_file = os.path.join(
                    self.output_directory, 
                    f"{os.path.splitext(os.path.basename(image_path))[0]}_metadata.json"
                )
                with open(metadata_file, 'w') as f:
                    json.dump(facial_data, f, indent=2)
        
        self.generate_report(analysis_results)
        print(f"Analysis complete. Results saved in {self.output_directory}")

def main():
    parser = argparse.ArgumentParser(description='Facial Feature Analysis Tool')
    parser.add_argument('input_dir', help='Directory containing images to analyze')
    args = parser.parse_args()
    
    if not os.path.exists(args.input_dir):
        print(f"Error: Directory {args.input_dir} does not exist")
        return
    
    analyzer = FacialAnalyzer(args.input_dir)
    analyzer.analyze_bulk_images()

if __name__ == "__main__":
    main()
